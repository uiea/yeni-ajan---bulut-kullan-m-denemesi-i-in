# Telegram BotFather'dan alınır. Bu örnek dosyaya gerçek anahtar yazma.
TELEGRAM_BOT_TOKEN=
# Botla ilk /start mesajını gönderdikten sonra sistemin izin vereceği sohbet kimliği.
TELEGRAM_ALLOWED_CHAT_ID=

# Ücretsiz stok medya API anahtarları. Gerçek anahtarları yalnızca .env.local dosyasına yaz.
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=

# Önizleme kaynağı önceliği. Bir kaynak hazır değilse sistem sıradakine geçer.
MEDIA_SOURCE_PRIORITY=pexels,pixabay,unsplash

# Yapay zekâ görseli seçeneği için ileride bağlanacak sağlayıcı.
# Ücretsiz stok medya akışında boş bırakılabilir.
AI_IMAGE_PROVIDER=
