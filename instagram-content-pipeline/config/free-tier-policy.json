{
  "mode": "free-first",
  "sources": {
    "pexels": {
      "enabled": true,
      "mediaTypes": ["image", "video"],
      "dailySearches": 20,
      "dailyDownloads": 10,
      "monthlySearches": 400,
      "monthlyDownloads": 200,
      "cacheHours": 168
    },
    "pixabay": {
      "enabled": true,
      "mediaTypes": ["image", "video"],
      "dailySearches": 15,
      "dailyDownloads": 8,
      "monthlySearches": 300,
      "monthlyDownloads": 150,
      "cacheHours": 168
    },
    "unsplash": {
      "enabled": true,
      "mediaTypes": ["image"],
      "dailySearches": 15,
      "dailyDownloads": 8,
      "monthlySearches": 300,
      "monthlyDownloads": 150,
      "cacheHours": 168
    }
  },
  "sourceRotation": {
    "single-image": ["unsplash", "pexels", "pixabay"],
    "carousel": ["unsplash", "pexels", "pixabay"],
    "reel": ["pexels", "pixabay"],
    "maxCandidatesPerSearch": 6,
    "maxDownloadsPerTopic": 3
  },
  "compliance": {
    "requireProvenance": true,
    "requireCreatorAndLicenseNote": true,
    "requireAttributionWhereProviderRequiresIt": true,
    "blockUnlicensedMusic": true,
    "blockTrademarkOrLogoUse": true,
    "neverRemoveWatermarksOrCopyrightNotices": true,
    "blockSensitivePersonContext": true,
    "blockBulkDownloading": true,
    "blockAutomatedMassEngagement": true,
    "humanReviewBeforeExternalAction": true,
    "retainSourceMetadataDays": 365
  },
  "telegram": {
    "maxTopicsPerDay": 5,
    "allowedChatIdsRequired": true
  },
  "instagram": {
    "maxPreparedPostsPerDay": 2,
    "maxPublishedPostsPerDay": 1,
    "humanReviewRequired": true,
    "scheduleOnlyViaOfficialApi": true,
    "requireAltText": true,
    "requireNoClaimsReview": true
  }
}
